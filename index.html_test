            } else {
                const users = JSON.parse(localStorage.getItem('zermango_users') || '[]');
                const uIdx = users.findIndex(u => u.username === username);
                if (uIdx !== -1) {
                    users[uIdx].purchasedKeys = users[uIdx].purchasedKeys || [];
                    if (status === 'approve') {
                        users[uIdx].balance = (users[uIdx].balance || 0) + amount;
                        users[uIdx].purchasedKeys.push({
                            productName: 'Nạp thẻ cào (Đã duy�!t)',
                            keys: [`Giao d�9ch: ${txId}`],
                            total: amount,
                            date: new Date().toLocaleString(),
                            paymentMethod: 'Card'
                        });
                    } else {
                        users[uIdx].purchasedKeys.push({
                            productName: 'Nạp thẻ cào (Thẻ sai)',
                            keys: [`Giao d�9ch: ${txId}`],
                            total: 0,
                            date: new Date().toLocaleString(),
                            paymentMethod: 'Card'
                        });
                    }
                    localStorage.setItem('zermango_users', JSON.stringify(users));
                }
            }
        }

        function handleTelegramQRDepositCallback(updateId, orderId, status, amount, username) {
            // Mark as processed
            const processedUpdates = JSON.parse(localStorage.getItem('zermango_processed_updates') || '[]');
            processedUpdates.push(updateId);
            localStorage.setItem('zermango_processed_updates', JSON.stringify(processedUpdates));
            
            const currentUser = JSON.parse(localStorage.getItem('zermango_user'));
            if (currentUser && currentUser.username === username) {
                if (status === 'approve') {
                    currentUser.balance = (currentUser.balance || 0) + amount;
                    currentUser.purchasedKeys = currentUser.purchasedKeys || [];
                    currentUser.purchasedKeys.push({
                        productName: 'Nạp tiền qua QR (Đã duy�!t)',
                        keys: [`Mã ĐH: ${orderId}`],
                        total: amount,
                        date: new Date().toLocaleString(),
                        paymentMethod: 'QR'
                    });
                    localStorage.setItem('zermango_user', JSON.stringify(currentUser));
                    
                    const users = JSON.parse(localStorage.getItem('zermango_users') || '[]');
                    const uIdx = users.findIndex(u => u.username === currentUser.username);
                    if (uIdx !== -1) {
                        users[uIdx].balance = currentUser.balance;
                        users[uIdx].purchasedKeys = currentUser.purchasedKeys;
                        localStorage.setItem('zermango_users', JSON.stringify(users));
                    }
                    
                    alert(`�S& Yêu cầu nạp tiền QR của bạn �ã �ược duy�!t thành công!\nS� dư tài khoản �ược c�"ng thêm: +${new Intl.NumberFormat('vi-VN').format(amount)} �.`);
                    window.location.reload();
                } else {
                    currentUser.purchasedKeys = currentUser.purchasedKeys || [];
                    currentUser.purchasedKeys.push({
                        productName: 'Nạp tiền qua QR (B�9 huỷ)',
                        keys: [`Mã ĐH: ${orderId}`],
                        total: 0,
                        date: new Date().toLocaleString(),
                        paymentMethod: 'QR'
                    });
                    localStorage.setItem('zermango_user', JSON.stringify(currentUser));
                    
                    const users = JSON.parse(localStorage.getItem('zermango_users') || '[]');
                    const uIdx = users.findIndex(u => u.username === currentUser.username);
                    if (uIdx !== -1) {
                        users[uIdx].purchasedKeys = currentUser.purchasedKeys;
                        localStorage.setItem('zermango_users', JSON.stringify(users));
                    }

                    alert(`�R Yêu cầu nạp tiền QR của bạn �ã b�9 từ ch�i duy�!t.\nVui lòng liên h�! Admin �Ồ �ược h� trợ!`);
                    window.location.reload();
                }
            } else {
                const users = JSON.parse(localStorage.getItem('zermango_users') || '[]');
                const uIdx = users.findIndex(u => u.username === username);
                if (uIdx !== -1) {
                    users[uIdx].purchasedKeys = users[uIdx].purchasedKeys || [];
                    if (status === 'approve') {
                        users[uIdx].balance = (users[uIdx].balance || 0) + amount;
                        users[uIdx].purchasedKeys.push({
                            productName: 'Nạp tiền qua QR (Đã duy�!t)',
                            keys: [`Mã ĐH: ${orderId}`],
                            total: amount,
                            date: new Date().toLocaleString(),
                            paymentMethod: 'QR'
                        });
                    } else {
                        users[uIdx].purchasedKeys.push({
                            productName: 'Nạp tiền qua QR (B�9 huỷ)',
                            keys: [`Mã ĐH: ${orderId}`],
                            total: 0,
                            date: new Date().toLocaleString(),
                            paymentMethod: 'QR'
                        });
                    }
                    localStorage.setItem('zermango_users', JSON.stringify(users));
                }
            }
        }

        // Start background Telegram polling
        document.addEventListener('DOMContentLoaded', () => {
            startTelegramPolling();
        });
    </script>
